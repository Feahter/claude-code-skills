import { test, expect } from '@playwright/test';

test('__TEST_NAME__', async ({ page }) => {
  await page.goto('__URL_PATH__');

  // 等接口完成的标准模式：先创建 promise，再触发动作
  const responsePromise = page.waitForResponse(
    r => r.url().includes('/api/') && r.request().method() === 'POST'
  );

  // TODO: 填表。优先级 Role > Label > Text > TestId
  // ⚠️ 按 project.json.uiLib 对照 references/selectors.md「UI 库特定坑」调整（MUI Select 走 getByRole('combobox')、Element Plus 走 getByLabel）
  // await page.getByLabel('邮箱').fill('test@example.com');
  // await page.getByLabel('密码').fill('password');

  await page.getByRole('button', { name: /提交|保存|确认/ }).click();

  const response = await responsePromise;
  expect(response.ok()).toBe(true);

  // 提交成功后的断言：URL 跳转或成功提示
  // await expect(page).toHaveURL(/\/success/);
  await expect(page.getByText(/成功|已提交|已保存/)).toBeVisible();
});
