import { describe, it, expect, beforeAll, afterEach, afterAll } from 'vitest';
import { render, screen } from '@testing-library/react';
import userEvent from '@testing-library/user-event';
import { setupServer } from 'msw/node';
import { http, HttpResponse } from 'msw';
import { __COMPONENT_NAME__ } from '__MODULE_PATH__';

// 组件集成测：组件 → hook → 接口 → 渲染 的真实数据流。网络层走 MSW 拦截，不 mock 内部模块。
// ⚠️ 用 userEvent 不用 fireEvent；用 getByRole/findBy 不用 querySelector；绝不 mock 子组件——只 mock MSW 这层真实 HTTP。
// 项目若有 renderWithProviders（test-utils）请改用它包裹 Provider。详见 references/unit-integration.md + references/mocking.md
const server = setupServer(
  // TODO: fixture 对齐后端真实响应形态（常见 { code: 0, data: {...} } 包裹层，平铺取不到值）
  http.get('__API_PATTERN__', () => HttpResponse.json({ items: [] })),
);
beforeAll(() => server.listen({ onUnhandledRequest: 'error' }));
afterEach(() => server.resetHandlers());  // 关键：重置避免用例间污染
afterAll(() => server.close());

describe('__TEST_NAME__', () => {
